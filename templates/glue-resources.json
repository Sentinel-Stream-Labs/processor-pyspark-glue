{
    "AWSTemplateFormatVersion": "2010-09-09",
    "Description": "AWS Glue Infrastructure for Sentinel Medallion Architecture",
    "Parameters": {
        "ProjectName": {
            "Type": "String",
            "Default": "sentinel-fraud-detection"
        }
    },
    "Resources": {
        "GlueJobRole": {
            "Type": "AWS::IAM::Role",
            "Properties": {
                "AssumeRolePolicyDocument": {
                    "Version": "2012-10-17",
                    "Statement": [
                        {
                            "Effect": "Allow",
                            "Principal": {
                                "Service": "glue.amazonaws.com"
                            },
                            "Action": "sts:AssumeRole"
                        }
                    ]
                },
                "ManagedPolicyArns": [
                    "arn:aws:iam::aws:policy/service-role/AWSGlueServiceRole"
                ],
                "Policies": [
                    {
                        "PolicyName": "SentinelProcessorPolicy",
                        "PolicyDocument": {
                            "Version": "2012-10-17",
                            "Statement": [
                                {
                                    "Effect": "Allow",
                                    "Action": [
                                        "kinesis:GetRecords",
                                        "kinesis:GetShardIterator",
                                        "kinesis:DescribeStream",
                                        "kinesis:ListShards",
                                        "kinesis:ListStreams"
                                    ],
                                    "Resource": [
                                        {
                                            "Fn::ImportValue": "Sentinel-KinesisStreamARN"
                                        },
                                        {
                                            "Fn::Sub": "arn:aws:kinesis:${AWS::Region}:${AWS::AccountId}:stream/*"
                                        }
                                    ]
                                },
                                {
                                    "Effect": "Allow",
                                    "Action": [
                                        "s3:PutObject",
                                        "s3:GetObject",
                                        "s3:DeleteObject",
                                        "s3:ListBucket"
                                    ],
                                    "Resource": [
                                        {
                                            "Fn::Sub": [
                                                "arn:aws:s3:::${BucketName}",
                                                {
                                                    "BucketName": {
                                                        "Fn::ImportValue": "Sentinel-DataLakeBucket"
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "Fn::Sub": [
                                                "arn:aws:s3:::${BucketName}/*",
                                                {
                                                    "BucketName": {
                                                        "Fn::ImportValue": "Sentinel-DataLakeBucket"
                                                    }
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "Effect": "Allow",
                                    "Action": [
                                        "glue:CreateTable",
                                        "glue:UpdateTable",
                                        "glue:GetTable",
                                        "glue:GetDatabase"
                                    ],
                                    "Resource": [
                                        {
                                            "Fn::Sub": "arn:aws:glue:${AWS::Region}:${AWS::AccountId}:catalog"
                                        },
                                        {
                                            "Fn::Sub": "arn:aws:glue:${AWS::Region}:${AWS::AccountId}:database/sentinel_fraud_db"
                                        },
                                        {
                                            "Fn::Sub": "arn:aws:glue:${AWS::Region}:${AWS::AccountId}:table/sentinel_fraud_db/*"
                                        }
                                    ]
                                },
                                {
                                    "Effect": "Allow",
                                    "Action": [
                                        "sns:Publish"
                                    ],
                                    "Resource": {
                                        "Fn::Sub": "arn:aws:sns:${AWS::Region}:${AWS::AccountId}:sentinel-fraud-alerts"
                                    }
                                },
                                {
                                    "Effect": "Allow",
                                    "Action": [
                                        "cloudwatch:PutMetricData"
                                    ],
                                    "Resource": "*"
                                }
                            ]
                        }
                    }
                ]
            }
        },
        "FraudDetectionGlueJob": {
            "Type": "AWS::Glue::Job",
            "Properties": {
                "Name": "sentinel-fraud-processor",
                "Role": {
                    "Ref": "GlueJobRole"
                },
                "Command": {
                    "Name": "gluestreaming",
                    "ScriptLocation": {
                        "Fn::Sub": [
                            "s3://${BucketName}/scripts/fraud_detection_processor.py",
                            {
                                "BucketName": {
                                    "Fn::ImportValue": "Sentinel-DataLakeBucket"
                                }
                            }
                        ]
                    },
                    "PythonVersion": "3"
                },
                "DefaultArguments": {
                    "--job-language": "python",
                    "--TempDir": {
                        "Fn::Sub": [
                            "s3://${BucketName}/temp/",
                            {
                                "BucketName": {
                                    "Fn::ImportValue": "Sentinel-DataLakeBucket"
                                }
                            }
                        ]
                    }
                },
                "GlueVersion": "4.0",
                "NumberOfWorkers": 2,
                "WorkerType": "G.1X"
            }
        },
        "SentinelGlueDatabase": {
            "Type": "AWS::Glue::Database",
            "Properties": {
                "CatalogId": {
                    "Ref": "AWS::AccountId"
                },
                "DatabaseInput": {
                    "Name": "sentinel_fraud_db"
                }
            }
        },
        "SentinelSilverCrawler": {
            "Type": "AWS::Glue::Crawler",
            "Properties": {
                "Name": "sentinel-silver-crawler",
                "Role": {
                    "Fn::GetAtt": [
                        "GlueJobRole",
                        "Arn"
                    ]
                },
                "DatabaseName": {
                    "Ref": "SentinelGlueDatabase"
                },
                "Configuration": "{\"Version\":1.0,\"CrawlerOutput\":{\"Tables\":{\"AddOrUpdateBehavior\":\"MergeNewColumns\"},\"Partitions\":{\"AddOrUpdateBehavior\":\"InheritFromTable\"}},\"Grouping\":{\"TableGroupingPolicy\":\"CombineCompatibleSchemas\"}}",
                "Targets": {
                    "S3Targets": [
                        {
                            "Path": {
                                "Fn::Sub": [
                                    "s3://${BucketName}/silver/",
                                    {
                                        "BucketName": {
                                            "Fn::ImportValue": "Sentinel-DataLakeBucket"
                                        }
                                    }
                                ]
                            },
                            "Exclusions": [
                                "_spark_metadata/**",
                                "_SUCCESS",
                                "temp/**",
                                "*.log"
                            ]
                        }
                    ]
                },
                "TablePrefix": "silver_",
                "SchemaChangePolicy": {
                    "UpdateBehavior": "UPDATE_IN_DATABASE",
                    "DeleteBehavior": "LOG"
                }
            }
        },
        "SentinelBronzeCrawler": {
            "Type": "AWS::Glue::Crawler",
            "Properties": {
                "Name": "sentinel-bronze-crawler",
                "Role": {
                    "Fn::GetAtt": [
                        "GlueJobRole",
                        "Arn"
                    ]
                },
                "DatabaseName": {
                    "Ref": "SentinelGlueDatabase"
                },
                "Configuration": "{\"Version\":1.0,\"CrawlerOutput\":{\"Tables\":{\"AddOrUpdateBehavior\":\"MergeNewColumns\"},\"Partitions\":{\"AddOrUpdateBehavior\":\"InheritFromTable\"}},\"Grouping\":{\"TableGroupingPolicy\":\"CombineCompatibleSchemas\"}}",
                "Targets": {
                    "S3Targets": [
                        {
                            "Path": {
                                "Fn::Sub": [
                                    "s3://${BucketName}/bronze/",
                                    {
                                        "BucketName": {
                                            "Fn::ImportValue": "Sentinel-DataLakeBucket"
                                        }
                                    }
                                ]
                            },
                            "Exclusions": [
                                "_spark_metadata/**",
                                "_SUCCESS",
                                "temp/**",
                                "*.log"
                            ]
                        }
                    ]
                },
                "TablePrefix": "bronze_",
                "SchemaChangePolicy": {
                    "UpdateBehavior": "UPDATE_IN_DATABASE",
                    "DeleteBehavior": "LOG"
                }
            }
        },
        "SentinelGoldCrawler": {
            "Type": "AWS::Glue::Crawler",
            "Properties": {
                "Name": "sentinel-gold-crawler",
                "Role": {
                    "Fn::GetAtt": [
                        "GlueJobRole",
                        "Arn"
                    ]
                },
                "DatabaseName": {
                    "Ref": "SentinelGlueDatabase"
                },
                "Configuration": "{\"Version\":1.0,\"CrawlerOutput\":{\"Tables\":{\"AddOrUpdateBehavior\":\"MergeNewColumns\"},\"Partitions\":{\"AddOrUpdateBehavior\":\"InheritFromTable\"}},\"Grouping\":{\"TableGroupingPolicy\":\"CombineCompatibleSchemas\"}}",
                "Targets": {
                    "S3Targets": [
                        {
                            "Path": {
                                "Fn::Sub": [
                                    "s3://${BucketName}/gold/",
                                    {
                                        "BucketName": {
                                            "Fn::ImportValue": "Sentinel-DataLakeBucket"
                                        }
                                    }
                                ]
                            },
                            "Exclusions": [
                                "_spark_metadata/**",
                                "_SUCCESS",
                                "temp/**",
                                "*.log"
                            ]
                        }
                    ]
                },
                "TablePrefix": "gold_",
                "SchemaChangePolicy": {
                    "UpdateBehavior": "UPDATE_IN_DATABASE",
                    "DeleteBehavior": "LOG"
                }
            }
        },
        "SentinelRawLayerCrawlerScheduleTrigger": {
            "Type": "AWS::Glue::Trigger",
            "DependsOn": [
                "SentinelBronzeCrawler",
                "SentinelSilverCrawler"
            ],
            "Properties": {
                "Name": "sentinel-raw-layer-crawler-hourly-trigger",
                "Type": "SCHEDULED",
                "Schedule": "cron(0 * * * ? *)",
                "StartOnCreation": true,
                "Description": "Runs the bronze and silver crawlers every hour to update the Glue Catalog",
                "Actions": [
                    {
                        "CrawlerName": {
                            "Ref": "SentinelBronzeCrawler"
                        }
                    },
                    {
                        "CrawlerName": {
                            "Ref": "SentinelSilverCrawler"
                        }
                    }
                ]
            }
        },
        "SentinelGoldCrawlerScheduleTrigger": {
            "Type": "AWS::Glue::Trigger",
            "DependsOn": [
                "SentinelGoldCrawler"
            ],
            "Properties": {
                "Name": "sentinel-gold-crawler-hourly-trigger",
                "Type": "SCHEDULED",
                "Schedule": "cron(5 * * * ? *)",
                "StartOnCreation": true,
                "Description": "Runs the gold crawler five minutes after the bronze and silver crawlers",
                "Actions": [
                    {
                        "CrawlerName": {
                            "Ref": "SentinelGoldCrawler"
                        }
                    }
                ]
            }
        },
        "SentinelFraudAlertsTopic": {
            "Type": "AWS::SNS::Topic",
            "Properties": {
                "TopicName": "sentinel-fraud-alerts",
                "DisplayName": "Sentinel Fraud Detection Alerts",
                "Tags": [
                    {
                        "Key": "Project",
                        "Value": "Sentinel-Fraud-Detection"
                    }
                ]
            }
        },
        "SentinelFraudAlertsSubscription": {
            "Type": "AWS::SNS::Subscription",
            "Properties": {
                "TopicArn": {
                    "Ref": "SentinelFraudAlertsTopic"
                },
                "Protocol": "email",
                "Endpoint": "bhavik.mundra1603@gmail.com"
            }
        }
    },
    "Outputs": {
        "SNSTopicArn": {
            "Value": {
                "Ref": "SentinelFraudAlertsTopic"
            },
            "Export": {
                "Name": "Sentinel-FraudAlertsTopic"
            },
            "Description": "ARN of SNS topic for fraud alerts"
        }
    }
}