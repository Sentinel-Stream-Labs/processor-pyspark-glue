{
    "AWSTemplateFormatVersion": "2010-09-09",
    "Description": "AWS Glue Infrastructure for Sentinel Medallion Architecture",
    "Parameters": {
        "ProjectName": {
            "Type": "String",
            "Default": "sentinel-fraud-detection"
        }
    },
    "Resources": {
        "GlueJobRole": {
            "Type": "AWS::IAM::Role",
            "Properties": {
                "AssumeRolePolicyDocument": {
                    "Version": "2012-10-17",
                    "Statement": [
                        {
                            "Effect": "Allow",
                            "Principal": {
                                "Service": "glue.amazonaws.com"
                            },
                            "Action": "sts:AssumeRole"
                        }
                    ]
                },
                "ManagedPolicyArns": [
                    "arn:aws:iam::aws:policy/service-role/AWSGlueServiceRole"
                ],
                "Policies": [
                    {
                        "PolicyName": "SentinelProcessorPolicy",
                        "PolicyDocument": {
                            "Version": "2012-10-17",
                            "Statement": [
                                {
                                    "Effect": "Allow",
                                    "Action": [
                                        "kinesis:GetRecords",
                                        "kinesis:GetShardIterator",
                                        "kinesis:DescribeStream",
                                        "kinesis:ListShards",
                                        "kinesis:ListStreams"
                                    ],
                                    "Resource": [
                                        {
                                            "Fn::ImportValue": "Sentinel-KinesisStreamARN"
                                        },
                                        {
                                            "Fn::Sub": "arn:aws:kinesis:${AWS::Region}:${AWS::AccountId}:stream/*"
                                        }
                                    ]
                                },
                                {
                                    "Effect": "Allow",
                                    "Action": [
                                        "s3:PutObject",
                                        "s3:GetObject",
                                        "s3:DeleteObject",
                                        "s3:ListBucket"
                                    ],
                                    "Resource": [
                                        {
                                            "Fn::Sub": [
                                                "arn:aws:s3:::${BucketName}",
                                                {
                                                    "BucketName": {
                                                        "Fn::ImportValue": "Sentinel-DataLakeBucket"
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "Fn::Sub": [
                                                "arn:aws:s3:::${BucketName}/*",
                                                {
                                                    "BucketName": {
                                                        "Fn::ImportValue": "Sentinel-DataLakeBucket"
                                                    }
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "Effect": "Allow",
                                    "Action": [
                                        "glue:CreateTable",
                                        "glue:UpdateTable",
                                        "glue:GetTable",
                                        "glue:GetDatabase"
                                    ],
                                    "Resource": [
                                        {
                                            "Fn::Sub": "arn:aws:glue:${AWS::Region}:${AWS::AccountId}:catalog"
                                        },
                                        {
                                            "Fn::Sub": "arn:aws:glue:${AWS::Region}:${AWS::AccountId}:database/sentinel_fraud_db"
                                        },
                                        {
                                            "Fn::Sub": "arn:aws:glue:${AWS::Region}:${AWS::AccountId}:table/sentinel_fraud_db/*"
                                        }
                                    ]
                                }
                            ]
                        }
                    }
                ]
            }
        },
        "FraudDetectionGlueJob": {
            "Type": "AWS::Glue::Job",
            "Properties": {
                "Name": "sentinel-fraud-processor",
                "Role": {
                    "Ref": "GlueJobRole"
                },
                "Command": {
                    "Name": "gluestreaming",
                    "ScriptLocation": {
                        "Fn::Sub": [
                            "s3://${BucketName}/scripts/fraud_detection_processor.py",
                            {
                                "BucketName": {
                                    "Fn::ImportValue": "Sentinel-DataLakeBucket"
                                }
                            }
                        ]
                    },
                    "PythonVersion": "3"
                },
                "DefaultArguments": {
                    "--job-language": "python",
                    "--TempDir": {
                        "Fn::Sub": [
                            "s3://${BucketName}/temp/",
                            {
                                "BucketName": {
                                    "Fn::ImportValue": "Sentinel-DataLakeBucket"
                                }
                            }
                        ]
                    }
                },
                "GlueVersion": "4.0",
                "NumberOfWorkers": 2,
                "WorkerType": "G.1X"
            }
        },
        "SentinelGlueDatabase": {
            "Type": "AWS::Glue::Database",
            "Properties": {
                "CatalogId": {
                    "Ref": "AWS::AccountId"
                },
                "DatabaseInput": {
                    "Name": "sentinel_fraud_db"
                }
            }
        },
        "SentinelSilverCrawler": {
            "Type": "AWS::Glue::Crawler",
            "Properties": {
                "Name": "sentinel-silver-crawler",
                "Role": {
                    "Fn::GetAtt": [
                        "GlueJobRole",
                        "Arn"
                    ]
                },
                "DatabaseName": {
                    "Ref": "SentinelGlueDatabase"
                },
                "Configuration": "{\"Version\":1.0,\"CrawlerOutput\":{\"Tables\":{\"AddOrUpdateBehavior\":\"MergeNewColumns\"},\"Partitions\":{\"AddOrUpdateBehavior\":\"InheritFromTable\"}},\"Grouping\":{\"TableGroupingPolicy\":\"CombineCompatibleSchemas\"}}",
                "Targets": {
                    "S3Targets": [
                        {
                            "Path": {
                                "Fn::Sub": [
                                    "s3://${BucketName}/silver",
                                    {
                                        "BucketName": {
                                            "Fn::ImportValue": "Sentinel-DataLakeBucket"
                                        }
                                    }
                                ]
                            },
                            "Exclusions": [
                                "_spark_metadata/**",
                                "_SUCCESS",
                                "temp/**"
                            ]
                        }
                    ]
                },
                "TableLevel": 2,
                "TablePrefix": "silver_"
            }
        },
        "SentinelBronzeCrawler": {
            "Type": "AWS::Glue::Crawler",
            "Properties": {
                "Name": "sentinel-bronze-crawler",
                "Role": {
                    "Fn::GetAtt": [
                        "GlueJobRole",
                        "Arn"
                    ]
                },
                "DatabaseName": {
                    "Ref": "SentinelGlueDatabase"
                },
                "Configuration": "{\"Version\":1.0,\"CrawlerOutput\":{\"Tables\":{\"AddOrUpdateBehavior\":\"MergeNewColumns\"},\"Partitions\":{\"AddOrUpdateBehavior\":\"InheritFromTable\"}},\"Grouping\":{\"TableGroupingPolicy\":\"CombineCompatibleSchemas\"}}",
                "Targets": {
                    "S3Targets": [
                        {
                            "Path": {
                                "Fn::Sub": [
                                    "s3://${BucketName}/bronze",
                                    {
                                        "BucketName": {
                                            "Fn::ImportValue": "Sentinel-DataLakeBucket"
                                        }
                                    }
                                ]
                            },
                            "Exclusions": [
                                "_spark_metadata/**",
                                "_SUCCESS",
                                "temp/**"
                            ]
                        }
                    ]
                },
                "TableLevel": 2,
                "TablePrefix": "bronze_"
            }
        }
    }
}